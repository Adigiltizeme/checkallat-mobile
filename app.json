{
  "expo": {
    "name": "CheckAll@t",
    "slug": "checkallat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#00B8A9"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.digiltizeme.checkallat",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#00B8A9"
      },
      "package": "com.digiltizeme.checkallat",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow CheckAll@t to use your location for nearby pros."
        }
      ],
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "c7b49218-9afc-4e25-9c72-9dc29e40917d"
      }
    }
  }
}
