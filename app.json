{
  "expo": {
    "name": "CheckAll@t",
    "slug": "checkallat",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "updates": {
      "enabled": false
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.digiltizeme.checkallat",
      "icon": "./assets/icon.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "CheckAll@t uses your camera to take before/after photos for service orders.",
        "NSPhotoLibraryUsageDescription": "CheckAll@t accesses your photos to upload profile pictures and proof photos.",
        "NSPhotoLibraryAddUsageDescription": "CheckAll@t saves photos to your library."
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#00B8A9"
      },
      "package": "com.digiltizeme.checkallat",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow CheckAll@t to use your location for nearby pros."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00B8A9",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "CheckAll@t accesses your photos to upload profile pictures and proof photos.",
          "cameraPermission": "CheckAll@t uses your camera to take before/after photos for service orders."
        }
      ],
      "expo-localization",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "checkallat-mobile",
          "organization": "digiltizeme"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "c7b49218-9afc-4e25-9c72-9dc29e40917d"
      }
    }
  }
}
