# API Backend
EXPO_PUBLIC_API_URL=http://localhost:4000/api/v1

# Mapbox (Carte, Directions, Géocodage inverse GPS)
# Obtenez votre token sur https://account.mapbox.com/
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Google Places API (Autocomplétion d'adresses — arabe, français, anglais, landmarks)
# Activez "Places API" dans Google Cloud Console → https://console.cloud.google.com/
# Utilisé en priorité sur Mapbox pour la recherche d'adresses (meilleur support Égypte/MENA)
EXPO_PUBLIC_GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Stripe (Paiements)
# Obtenez votre clé sur https://dashboard.stripe.com/
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Environment
EXPO_PUBLIC_ENV=development
